# Shoonya API Local Proxy Configuration
# Fill in your trading credentials here. Keep this file private.

# Local proxy server port
PORT=5600

# 1. Your Shoonya User ID (e.g., FA12345)
SHOONYA_USER_ID=FN213354

# 2. Your Shoonya Login Password (clear text - the proxy will automatically SHA256-hash it for security)
SHOONYA_PASSWORD=R@js2004

# 3. Your 2FA TOTP Secret Key (from Shoonya security settings, used to generate TOTP automatically)
# This is usually a 32-character base32 alphanumeric key (e.g., ORXW633PN5XW633P...)
SHOONYA_TOTP_SECRET=V5DWV7DG2724PQ36H4RUG33665Y2PXE6

# 4. Your API Secret Key / AppKey (generated from the Shoonya Prism portal)
SHOONYA_API_SECRET=eaad4dfcfa71b98f9a0e9325399c2b2a

# 5. Your Vendor Code (e.g., FA12345_UAT or your registered vendor code)
SHOONYA_VENDOR_CODE=FN213354_U

# 6. Your registered MAC address or unique device identifier
# (Often a standard format like your computer MAC address or "12345678" depending on registration)
SHOONYA_IMEI=abc1234
